{
  "name": "heloccalcpro",
  "version": "1.0.0",
  "description": "Professional HELOC Calculator with AI-powered financial analysis and risk assessment",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/Heloccalcpro.git"
  },
  "keywords": [
    "heloc",
    "calculator",
    "home-equity",
    "financial-analysis",
    "mortgage",
    "nextjs",
    "typescript",
    "ai-analysis"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:https": "node server-https.mjs",
    "build": "prisma generate && bash scripts/pre-build.sh && next build",
    "build:local": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "node -e \"const { execSync } = require('child_process'); const skip = process.env.VERCEL === '1' || process.env.SKIP_PLAYWRIGHT_INSTALL === '1'; if (skip) { console.log('Skipping Playwright install during prepare script'); process.exit(0); } execSync('npx playwright install --with-deps', { stdio: 'inherit' });\"",
    "generate:robots": "tsx scripts/generate-robots.ts",
    "generate:cert": "node scripts/generate-cert.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.18.0",
    "@react-pdf/renderer": "^4.3.2",
    "chart.js": "^4.5.1",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.40",
    "lucide-react": "^0.546.0",
    "next": "14.2.5",
    "next-auth": "^4.24.12",
    "next-intl": "^4.4.0",
    "nodemailer": "^7.0.10",
    "react": "^18",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18",
    "react-katex": "^3.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.2",
    "scoop": "^0.0.2",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-katex": "^3.0.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.0.1",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prisma": "^6.18.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
