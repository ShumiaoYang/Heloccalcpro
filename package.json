{
  "name": "ai-tools-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "playwright install --with-deps",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:robots": "tsx scripts/generate-robots.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.18.0",
    "lucide-react": "^0.546.0",
    "next": "14.2.5",
    "next-auth": "^4.24.12",
    "next-intl": "^4.4.0",
    "nodemailer": "^7.0.10",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.0.1",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prisma": "^6.18.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
