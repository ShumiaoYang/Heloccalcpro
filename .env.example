# Application
APP_DOMAIN="http://localhost:3000"
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/heloc_calculator?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Services - OpenAI GPT-5
OPENAI_API_KEY_GPT5="your-openai-api-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-5.1-thinking-all"
OPENAI_TEMPERATURE="0.7"
OPENAI_MAX_TOKENS="2000"
OPENAI_SUMMARIZER_TEMP="0.2"

# AI Services - Google Gemini
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-3-flash-preview-thinking"
GEMINI_TEMPERATURE="0.7"
GEMINI_MAX_TOKENS="2000"

# AI Configuration
AI_ANALYSIS_TIMEOUT="60000"
AI_MAX_RETRIES="3"

# Stripe Payment (Test Mode)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
STRIPE_PRICE_HELOC_REPORT="price_your_price_id_here"
STRIPE_MOCK_MODE="true"

# PDF Security
PDF_ACCESS_TOKEN_SECRET="your-pdf-token-secret-key-here"
PDF_TOKEN_EXPIRY_HOURS="24"

# Chart Generation
CHART_CACHE_ENABLED="true"
CHART_CACHE_TTL="3600"

# Cloudflare R2 Storage
R2_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="heloc-pdfs"
R2_PUBLIC_URL="https://your-custom-domain.com"

# Email Service (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="HELOC Calculator <noreply@heloccalculator.pro>"

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Tool Configuration (Legacy - can be removed if not using AI tools feature)
TOOL_SUMMARIZER_PROVIDER="mock"
TOOL_SUMMARIZER_MODEL="gpt-5.1-thinking-all"
