# ============================================
# HELOC Calculator - Environment Configuration
# ============================================
# 本文件包含所有需要配置的环境变量
# 部署到 Vercel 时，将这些变量添加到 Environment Variables 中

# ============================================
# 1. Application
# ============================================
APP_DOMAIN="https://localhost:3000"

# ============================================
# 1. NextAuth Configuration (认证配置)
# ============================================
# NEXTAUTH_SECRET: 用于加密 session 和 token 的密钥
# 生成方法: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here-change-in-production"

# NEXTAUTH_URL: 应用的完整 URL
# 本地开发: http://localhost:3000
# 生产环境: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"


# ============================================
# 2. Google OAuth (Google 登录配置)
# ============================================
# 配置步骤：
# 1. 访问 https://console.cloud.google.com/
# 2. 创建新项目或选择现有项目
# 3. 启用 "Google+ API"
# 4. 创建 OAuth 2.0 凭据：
#    - 应用类型：Web application
#    - 授权重定向 URI：
#      本地: http://localhost:3000/api/auth/callback/google
#      生产: https://your-domain.com/api/auth/callback/google
# 5. 复制 Client ID 和 Client Secret

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"


# ============================================
# 3. Database (数据库配置)
# ============================================
# PostgreSQL 数据库连接字符串
# 格式: postgresql://username:password@host:port/database
#
# 推荐的免费 PostgreSQL 服务：
#
# 选项1: Supabase (推荐)
# - 网址: https://supabase.com/
# - 免费额度: 500MB 数据库, 无限 API 请求
# - 获取连接字符串: Project Settings → Database → Connection string
#
# 选项2: Neon
# - 网址: https://neon.tech/
# - 免费额度: 3GB 存储, 无限查询
# - 获取连接字符串: Dashboard → Connection Details
#
# 选项3: Vercel Postgres
# - 网址: https://vercel.com/storage/postgres
# - 免费额度: 256MB 存储
# - 自动集成到 Vercel 项目

DATABASE_URL="postgresql://user:password@localhost:5432/heloc_calculator?schema=public"

# ============================================
# 4. AI Services (AI 服务配置)
# ============================================

# --- OpenAI GPT-5 ---
# 用于生成 HELOC 分析报告
# 获取 API Key: https://platform.openai.com/api-keys
# 定价: 按 token 计费，约 $0.01-0.03 per 1K tokens
OPENAI_BASE_URL="URL-of-the-API-Service"
OPENAI_API_KEY_GPT5="your-openai-api-key-here"
OPENAI_MODEL="Name-of-LLM-model"
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# --- Google Gemini ---
# 备用 AI 服务
# 如果使用官方 Gemini API，改为: https://generativelanguage.googleapis.com/v1beta
# 获取 API Key: https://makersuite.google.com/app/apikey
# 免费额度: 60 requests/minute
GEMINI_BASE_URL="URL-of-the-API-Service"
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="Name-of-LLM-model"
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4000

AI_ANALYSIS_TIMEOUT=60000
AI_MAX_RETRIES=3


# ============================================
# 5. Stripe Payment (支付配置)
# ============================================
# 用于 PDF 报告购买功能
# 注册: https://dashboard.stripe.com/register
#
# 配置步骤:
# 1. 创建 Stripe 账户
# 2. 获取测试密钥: Dashboard → Developers → API keys
# 3. 创建产品和价格: Dashboard → Products → Add product
# 4. 配置 Webhook: Dashboard → Developers → Webhooks
#    - Endpoint URL: https://your-domain.com/api/billing/webhook
#    - 监听事件: checkout.session.completed, payment_intent.succeeded

# 测试模式密钥 (以 sk_test_ 开头)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# 产品价格 ID (从 Stripe Dashboard 获取)
STRIPE_PRICE_HELOC_REPORT="price_your_price_id_here"

# 订阅计划价格 ID（如果不使用订阅功能，保持占位符即可）
STRIPE_PRICE_PRO_MONTHLY="price_placeholder_monthly"
STRIPE_PRICE_PRO_ANNUAL="price_placeholder_annual"

# ============================================
# 6. Email Service (邮件服务配置)
# ============================================
# Gmail SMTP 配置
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user@gmail.com"
SMTP_PASSWORD="google's app password"
SMTP_FROM="Title <user@gmail.com>"

# ============================================
# 7. Cloudflare R2
# ============================================
R2_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-r2-bucket-name"
R2_PUBLIC_URL="https://your-custom-domain.com"

# ============================================
# 8. Google Analytics (网站分析)
# ============================================
# Google Analytics Measurement ID
# 获取方法：
# 1. 登录 https://analytics.google.com/
# 2. 选择你的网站属性
# 3. 进入 Admin → Data Streams → 选择你的数据流
# 4. 复制 Measurement ID (格式: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"


# PDF Security
PDF_ACCESS_TOKEN_SECRET="your-pdf-token-secret-key-here"
PDF_TOKEN_EXPIRY_HOURS="24"

# Chart Generation
CHART_CACHE_ENABLED="true"
CHART_CACHE_TTL="3600"

# Tool Configuration (Legacy - can be removed if not using AI tools feature)
TOOL_SUMMARIZER_PROVIDER="mock"
TOOL_SUMMARIZER_MODEL="gpt-5.1-thinking-all"
